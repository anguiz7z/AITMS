  "$id": "https://raw.githubusercontent.com/anguiz7z/AITMS/main/docs/system.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "The user-supplied AI system description (input to the workflow).",
  "properties": {
    "business_context": {
      "default": "",
      "title": "Business Context",
      "type": "string"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/Component"
      },
      "title": "Components",
      "type": "array"
    },
    "dataflows": {
      "items": {
        "$ref": "#/$defs/Dataflow"
      },
      "title": "Dataflows",
      "type": "array"
    },
    "deployment_stage": {
      "default": "pilot",
      "enum": [
        "poc",
        "pilot",
        "production"
      ],
      "title": "Deployment Stage",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "industry": {
      "default": "midmarket_other",
      "enum": [
        "tier1_bank",
        "regional_bank",
        "fintech",
        "insurer",
        "healthcare_provider",
        "pharma_biotech",
        "tech_saas",
        "ecommerce",
        "media_entertainment",
        "telecom",
        "manufacturing",
        "energy_utility",
        "critical_infrastructure",
        "government_defense",
        "education",
        "smb_other",
        "midmarket_other"
      ],
      "title": "Industry",
      "type": "string"
    },
    "is_high_risk_under_eu_ai_act": {
      "default": false,
      "title": "Is High Risk Under Eu Ai Act",
      "type": "boolean"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "revenue_bucket": {
      "default": "unknown",
      "enum": [
        "under_50m",
        "50m_to_500m",
        "500m_to_5b",
        "over_5b",
        "unknown"
      ],
      "title": "Revenue Bucket",
      "type": "string"
    },
    "trust_boundaries": {
      "items": {
        "$ref": "#/$defs/TrustBoundary"
      },
      "title": "Trust Boundaries",
      "type": "array"
    }
